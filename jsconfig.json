{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["esnext", "dom"]
    },
    "include": ["src/**/*", "src-electron/**/*"],
    "exclude": ["node_modules", "build"]
}
