# MOCK RUNTIME ONLY
# Copy values from here into your shell, `.env.local`, or a dedicated env file when using `dev-mock`.

VITE_MOCK_RUNTIME=1

# Dataset size
VITE_MOCK_FRIEND_COUNT=2000
VITE_MOCK_GROUP_COUNT=64
VITE_MOCK_WORLD_COUNT=420
VITE_MOCK_AVATAR_COUNT=320
VITE_MOCK_INSTANCE_COUNT=320

# Dataset distribution
VITE_MOCK_ONLINE_RATIO=0.28
VITE_MOCK_ACTIVE_RATIO=0.08
VITE_MOCK_TRAVELING_RATIO=0.05

# Fake WebSocket behavior
VITE_MOCK_WS_INTERVAL_MS=1000
VITE_MOCK_WS_BATCH_SIZE=3
VITE_MOCK_WS_LOCATION_WEIGHT=6
VITE_MOCK_WS_ONLINE_WEIGHT=2
VITE_MOCK_WS_OFFLINE_WEIGHT=1
VITE_MOCK_WS_UPDATE_WEIGHT=2
VITE_MOCK_WS_ACTIVE_WEIGHT=1
VITE_MOCK_WS_COHORT_SIZE=3
VITE_MOCK_WS_CLUSTER_WEIGHT=3
VITE_MOCK_WS_SPLIT_WEIGHT=2
VITE_MOCK_WS_CHAOS_WEIGHT=2

# Fake game log / player list behavior
VITE_MOCK_LOG_INTERVAL_MS=3500
VITE_MOCK_LOG_BATCH_SIZE=3
VITE_MOCK_LOG_MIN_PLAYERS=6
VITE_MOCK_LOG_MAX_PLAYERS=18
VITE_MOCK_LOG_JOIN_WEIGHT=5
VITE_MOCK_LOG_LEAVE_WEIGHT=3
VITE_MOCK_LOG_AVATAR_WEIGHT=2
VITE_MOCK_LOG_PORTAL_WEIGHT=1
VITE_MOCK_LOG_VIDEO_WEIGHT=1
VITE_MOCK_LOG_PHOTON_WEIGHT=2
VITE_MOCK_LOG_STICKER_WEIGHT=1
VITE_MOCK_LOG_TRAVEL_WEIGHT=1
